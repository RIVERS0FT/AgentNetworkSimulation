# EditorConfig — 跨编辑器统一编码风格
# 与 .gitattributes 配合使用
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,css,html,json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.sh]
indent_style = tab
