  "network_generation_rules": [
    {
      "sub_id": "sub_market",
      "topology_type": "MESH",
      "description": "招投标市场平面：所有机构与所有运营商可互相报价谈判",
      "generation_rule": "BIPARTITE",
      "source_categories": ["government_agency", "financial_institution", "educational_institution", "healthcare_institution", "industrial_enterprise"],
      "target_categories": ["telecom_operator", "virtual_operator"],
      "paradigm": "NEGOTIATION",
      "edge_density": { "inter": 0.0002 },
      "max_total_edges": 30000000,
      "channel_prefix": "vlan_market"
    },
    {
      "sub_id": "sub_agency_collab",
      "topology_type": "MESH",
      "description": "机构间信息共享网络：同类机构交流招标经验和市场情报",
      "generation_rule": "INTRA_CATEGORY_FULL_INTER_CATEGORY_SPARSE",
      "source_categories": ["government_agency", "financial_institution", "educational_institution", "healthcare_institution", "industrial_enterprise"],
      "target_categories": ["government_agency", "financial_institution", "educational_institution", "healthcare_institution", "industrial_enterprise"],
      "paradigm": "COLLABORATION",
      "edge_density": { "intra": 0.00002, "inter": 0.000005 },
      "max_total_edges": 10000000,
      "channel_prefix": "vlan_agency"
    },
    {
      "sub_id": "sub_operator_compete",
      "topology_type": "MESH",
      "description": "运营商竞争情报网络：运营商间互相监测定价和市场动态",
      "generation_rule": "INTRA_CATEGORY_FULL_INTER_CATEGORY_SPARSE",
      "source_categories": ["telecom_operator", "virtual_operator"],
      "target_categories": ["telecom_operator", "virtual_operator"],
      "paradigm": "GAME",
      "edge_density": { "intra": 0.001, "inter": 0.0005 },
      "max_total_edges": 5000000,
      "channel_prefix": "vlan_op_compete"
    },
    {
      "sub_id": "sub_regulatory",
      "topology_type": "STAR",
      "description": "监管平面：监管机构监督所有运营商和大型机构",
      "generation_rule": "STAR_HUB",
      "hub_categories": ["regulator"],
      "spoke_categories": ["telecom_operator", "virtual_operator", "government_agency", "financial_institution", "industrial_enterprise"],
      "paradigm": "NEGOTIATION",
      "edge_density": { "hub_to_spoke": 0.05 },
      "max_total_edges": 10000000,
      "channel_prefix": "vlan_reg"
    },
    {
      "sub_id": "sub_consulting",
      "topology_type": "STAR",
      "description": "咨询服务平面：咨询顾问连接所有机构侧和运营商侧",
      "generation_rule": "STAR_HUB",
      "hub_categories": ["consultant"],
      "spoke_categories": ["government_agency", "financial_institution", "educational_institution", "healthcare_institution", "industrial_enterprise", "telecom_operator", "virtual_operator"],
      "paradigm": "NEGOTIATION",
      "edge_density": { "hub_to_spoke": 0.01 },
      "max_total_edges": 15000000,
      "channel_prefix": "vlan_consult"
    }
  ],

  "network_global_constraints": {
    "max_total_edges_across_all_subnets": 80000000,
    "max_edges_per_agent_global": 400,
    "oversubscription_ratio": { "telecom_operator": 300, "virtual_operator": 50, "regulator": 80, "consultant": 40, "government_agency": 30, "financial_institution": 25, "industrial_enterprise": 20, "educational_institution": 15, "healthcare_institution": 12 },
    "bandwidth_limits_gbps": {
      "EAST_WEST":   { "per_agent_avg_mbps": 0.5,  "total_aggregate_gbps": 500 },
      "NORTH_SOUTH": { "per_agent_avg_mbps": 2,    "total_aggregate_gbps": 2000 },
      "INTERNAL":    { "per_agent_avg_mbps": 5,    "total_aggregate_gbps": 5000 }
    }
  },

  "business_topology_rules": {
    "_description": "合约生命周期动态规则。业务拓扑由种子 links 初始化，运行时由技能驱动演进",
    "seed_generation": {
      "enabled": true,
      "max_seed_links": 50000,
      "generation_rule": "RANDOM_SAMPLE",
      "source_categories": ["government_agency", "financial_institution", "educational_institution", "healthcare_institution", "industrial_enterprise"],
      "target_categories": ["telecom_operator", "virtual_operator"],
      "initial_status": "NEGOTIATING",
      "value_range": { "min": 100, "max": 5000 }
    },
    "contract_lifecycle": {
      "statuses": ["NEGOTIATING", "SIGNED", "BREACH_FLASHING", "TERMINATED"],
      "transition_triggers": {
        "NEGOTIATING→SIGNED": "sign_contract",
        "SIGNED→BREACH_FLASHING": "terminate_contract_with_flash",
        "BREACH_FLASHING→TERMINATED": "confirm_termination"
      },
      "avg_contract_duration_rounds": { "telecom_operator": 8, "virtual_operator": 5 },
      "breach_probability_per_round": 0.08,
      "event_log_enabled": true
    }
  },

  "traffic_generation_rules": {
    "EAST_WEST": {
      "description": "Agent间东西向协作流量（招标通知/评标讨论/合同协商/投诉调查）",
      "generated_by": ["evaluate_proposals", "notify_team", "investigate_complaint", "provide_evaluation_report"],
      "avg_requests_per_agent_per_round": 0.25,
      "size_distribution": { "min_kb": 1, "p50_kb": 16, "p95_kb": 64, "max_kb": 512 }
    },
    "NORTH_SOUTH": {
      "description": "外部API调用南北向流量（运营商报价/信用评估/法规查询）",
      "generated_by": ["submit_bidding_proposal", "request_external_api"],
      "avg_requests_per_agent_per_round": 0.08,
      "size_distribution": { "min_kb": 4, "p50_kb": 64, "p95_kb": 256, "max_kb": 4096 },
      "rate_limit_per_round_global": 100000
    },
    "INTERNAL": {
      "description": "内部管理流量（合同归档/审计报告/市场分析）",
      "generated_by": ["sign_contract", "terminate_contract_with_flash", "audit_market_share", "impose_sanction", "handle_push"],
      "avg_requests_per_agent_per_round": 0.15,
      "size_distribution": { "min_kb": 1, "p50_kb": 64, "p95_kb": 1024, "max_kb": 16384 }
    }
  },

