FROM python:3.12-slim

WORKDIR /app

# Parser only: srv never captures its own interface. Agent containers write the
# PCAP files; srv uses tcpdump -r to expose structured analysis through the API.
RUN apt-get update && apt-get install -y --no-install-recommends tcpdump \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY agent_network/ /app/agent_network/
COPY services/server.py /app/services/
COPY web/ /app/web/
COPY scenes/ /app/scenes/

ENV SERVER_PORT=8000
ENV MESSAGE_BUS_URL=http://localhost:9000

EXPOSE 8000

CMD ["python", "services/server.py", "--host", "0.0.0.0"]
