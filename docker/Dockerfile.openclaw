FROM node:22-slim

# Debian 国内镜像加速
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || true

# Python is used by AgentNetwork's agent server and openclaw-sdk. Node is kept
# in the image because the OpenCLAW gateway/runtime is expected to be installed
# as a Node/TypeScript command inside the same container.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv python3-requests python-is-python3 \
    tcpdump ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Optional gateway runtime install hook. Set at build time once the real
# OpenCLAW gateway npm package name is known, for example:
#   docker compose build --build-arg OPENCLAW_GATEWAY_NPM_PACKAGE=<pkg> ag-o1
ARG OPENCLAW_GATEWAY_NPM_PACKAGE=""
RUN set -eux; \
    npm config set registry https://registry.npmmirror.com; \
    if [ -n "$OPENCLAW_GATEWAY_NPM_PACKAGE" ]; then \
        npm install -g "$OPENCLAW_GATEWAY_NPM_PACKAGE"; \
    fi

WORKDIR /app

COPY requirements.txt .
RUN python3 -m pip install --no-cache-dir --break-system-packages -r requirements.txt

# Install only the supported OpenCLAW SDK wheel. Do not install every wheel in
# vendor/python because that directory may contain host/Python-version-specific
# wheels such as cp312 artifacts.
COPY vendor/python/ /tmp/vendor/python/
RUN set -eux; \
    if ls /tmp/vendor/python/openclaw_sdk-*.whl >/dev/null 2>&1; then \
        python3 -m pip install --no-cache-dir --break-system-packages /tmp/vendor/python/openclaw_sdk-*.whl; \
    fi

COPY services/agent_server.py /app/services/
COPY agent_network/ /app/agent_network/
COPY scenes/ /app/scenes/
COPY docker/start-openclaw-agent.sh /app/start-openclaw-agent.sh
RUN chmod +x /app/start-openclaw-agent.sh

# 注意: 使用 docker-compose 部署时，通过 environment 覆盖为 service name:
#   MESSAGE_BUS_URL=http://bus:9000
#   SERVER_URL=http://srv:8000
# OpenCLAW gateway is intentionally local to this Agent container by default.
ENV PYTHONPATH="/app"
ENV AGENT_ID="agent-001"
ENV AGENT_ROLE="generic"
ENV AGENT_NAME="Agent"
ENV MESSAGE_BUS_URL="http://localhost:9000"
ENV SERVER_URL="http://localhost:8000"
ENV AGENT_BACKEND="openclaw"
ENV OPENCLAW_START_GATEWAY="1"
ENV OPENCLAW_GATEWAY_HOST="127.0.0.1"
ENV OPENCLAW_GATEWAY_PORT="18789"
ENV OPENCLAW_GATEWAY_WS_URL="ws://127.0.0.1:18789/gateway"

EXPOSE 8000

CMD ["/app/start-openclaw-agent.sh"]