# ============================================
# Auto-detect text files, normalize to LF by default
# ============================================
* text=auto

# ============================================
# Source code — force LF
# ============================================
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# ============================================
# Config / Documentation — force LF
# ============================================
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.conf text eol=lf
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
requirements.txt text eol=lf
Makefile text eol=lf

# ============================================
# Scripts — force LF (shebangs need LF on Linux)
# ============================================
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# ============================================
# Windows batch files — keep CRLF (required)
# ============================================
*.bat text eol=crlf
*.cmd text eol=crlf

# ============================================
# Binary files — don't touch
# ============================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.bmp binary
*.tiff binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.webm binary
*.wasm binary
*.pyc binary
*.pyd binary
*.so binary
*.o binary
*.a binary
*.lib binary
*.dll binary
*.exe binary
*.bin binary
*.dat binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.ico binary
*.icns binary
